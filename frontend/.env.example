# ============================================================
# Frontend Environment Variables
# Copy to .env.local for local development
# ============================================================

# Backend API URL (public — used in browser)
NEXT_PUBLIC_API_URL=https://api.raheeqarabia.com

# Backend URL (server-side only — used by Next.js API routes)
BACKEND_URL=https://api.raheeqarabia.com

# Backend API key for server-to-server calls
BACKEND_API_KEY=change_me_in_production

# Site URL
NEXT_PUBLIC_SITE_URL=https://raheeqarabia.com

# ============================================================
# Pixel IDs (set after ad accounts are connected)
# ============================================================
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAP_PIXEL_ID=
