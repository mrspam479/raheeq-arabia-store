# Raheeq Arabia — Frontend env (.env.example)
# Copy to frontend/.env.local for local dev. In EasyPanel, set the same vars on the Next.js service.

# --- Public (shipped to the browser) ---

# Base URL of the FastAPI backend (https in prod)
NEXT_PUBLIC_API_BASE_URL=https://api.raheeqarabia.com

# Brand site root (used for canonical URLs + OG tags)
NEXT_PUBLIC_SITE_URL=https://raheeqarabia.com

# Pixels (set after platforms are created)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_CODE=
NEXT_PUBLIC_SNAP_PIXEL_ID=

# Optional social links (footer)
NEXT_PUBLIC_SOCIAL_SNAP=https://snapchat.com/add/raheeqarabia
NEXT_PUBLIC_SOCIAL_TIKTOK=https://www.tiktok.com/@raheeqarabia
NEXT_PUBLIC_SOCIAL_IG=https://instagram.com/raheeqarabia

# Feature flags
NEXT_PUBLIC_CONTACT_FORM_ENABLED=false
NEXT_PUBLIC_SFDA_BADGE_ENABLED=false

# --- Server-only (used by app/api/* proxy routes) ---

# API key used when calling the backend's /api/track endpoint server-side
BACKEND_API_KEY=

# Optional: do-not-track override for dev
ALLOW_DEV_TRACKING=false
