APP_ENV=production
APP_NAME=Raheeq Arabia API
API_BASE_URL=https://api.raheeqarabia.com
FRONTEND_URL=https://raheeqarabia.com

DATABASE_URL=postgresql+psycopg://raheeqarabia:raheeqarabia@raheeqarabia_database:5432/raheeqarabia

SECRET_KEY=
BACKEND_API_KEY=

CORS_ORIGINS=https://raheeqarabia.com,http://localhost:3000
PROXY_TRUST_HOPS=1

SHEET_WEBHOOK_URL=
SHEET_WEBHOOK_SECRET=

META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v20.0
META_TEST_EVENT_CODE=

TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_VERSION=v1.3
TIKTOK_TEST_EVENT_CODE=

SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
SNAP_TEST_EVENT_CODE=

ENABLE_CAPI=true
ENABLE_META_CAPI=true
ENABLE_TIKTOK_CAPI=true
ENABLE_SNAP_CAPI=true

# ─────────────────────────────────────────────────────────────────
# MaxMind GeoIP2 — STRICT KSA-only IP blocking + VPN/Proxy detection
# ─────────────────────────────────────────────────────────────────
# Behavior when ENABLE_IP_FRAUD_CHECK=true:
#   ✅ Allow ONLY IPs physically in Saudi Arabia (country ISO == "SA")
#   ❌ Block anonymous VPN, public proxy, residential proxy, TOR, hosting/data-center
#   ❌ Block timeout / API errors (fail-closed for security)
#
# How to get your keys:
#   1. Sign up: https://www.maxmind.com/en/geoip2-precision-services
#   2. Buy "GeoIP2 Precision: Insights" (recommended — includes country + VPN/proxy flags)
#      OR "GeoIP2 Precision: Country" + "GeoIP2 Anonymous IP" if budget-conscious
#   3. Generate a license key: https://www.maxmind.com/en/accounts/current/license-key
#   4. Paste your numeric Account ID and the license key below.
#
# Pricing reference: ~$0.001-0.004 per query in pay-as-you-go = ~$1-4 for 1,000 orders.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Optional: path to a self-hosted MaxMind .mmdb file (avoids per-query API cost).
# Leave empty to use the web service above.
MAXMIND_DB_PATH=

# Master switch. Set to false ONLY in local dev. MUST be true in production.
ENABLE_IP_FRAUD_CHECK=true

# Comma-separated phones that bypass ALL fraud checks.
# Use 050000001 to place a real test order from anywhere in the world.
WHITELISTED_PHONES=0500000001,050000001,050000007,055000000

LOG_LEVEL=INFO
