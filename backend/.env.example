APP_ENV=production
APP_NAME=Raheeq Arabia API
API_BASE_URL=https://api.raheeqarabia.com
FRONTEND_URL=https://raheeqarabia.com

DATABASE_URL=postgresql+psycopg://raheeqarabia:raheeqarabia@raheeqarabia_database:5432/raheeqarabia

SECRET_KEY=
BACKEND_API_KEY=

CORS_ORIGINS=https://raheeqarabia.com,http://localhost:3000
PROXY_TRUST_HOPS=1

SHEET_WEBHOOK_URL=
SHEET_WEBHOOK_SECRET=

META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v20.0
META_TEST_EVENT_CODE=

TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_VERSION=v1.3
TIKTOK_TEST_EVENT_CODE=

SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
SNAP_TEST_EVENT_CODE=

ENABLE_CAPI=true
ENABLE_META_CAPI=true
ENABLE_TIKTOK_CAPI=true
ENABLE_SNAP_CAPI=true

# MaxMind GeoIP2 — used to block non-KSA / VPN / suspicious IPs
# Sign up: https://www.maxmind.com/en/geoip2-precision-insights
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
ENABLE_IP_FRAUD_CHECK=true

# Comma-separated phones that bypass the IP fraud check (for testing)
WHITELISTED_PHONES=050000007,055000000

LOG_LEVEL=INFO
