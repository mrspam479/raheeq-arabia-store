# Raheeq Arabia — Backend env (.env.example)
# Copy to backend/.env for local dev. In EasyPanel, set these on the FastAPI service.

# --- App ---
APP_ENV=production
LOG_LEVEL=INFO

# --- Database (EasyPanel internal URL) ---
# SQLAlchemy needs `postgresql+psycopg://` scheme; psycopg ignores ?sslmode in URL,
# the code passes sslmode=disable via connect_args for the EasyPanel internal connection.
DATABASE_URL=postgresql+psycopg://raheeqarabia:raheeqarabia@raheeqarabia_database:5432/raheeqarabia

# --- Security ---
# Strong random 32-byte b64. Used by itsdangerous (upsell token) and similar.
SECRET_KEY=

# Strong random 32-byte b64. Required by /api/admin/* and /api/track.
BACKEND_API_KEY=

# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=https://raheeqarabia.com,http://localhost:3000

# How many proxy hops to trust for client IP (EasyPanel = 1)
PROXY_TRUST_HOPS=1

# --- Google Sheets Webhook ---
SHEET_WEBHOOK_URL=
SHEET_WEBHOOK_SECRET=

# --- Meta Conversions API ---
META_PIXEL_ID=
META_ACCESS_TOKEN=
# Leave empty in production. During QA set to the test code shown in Events Manager → Test Events.
META_TEST_EVENT_CODE=

# --- TikTok Events API ---
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

# --- Snapchat Conversions API ---
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
SNAP_TEST_EVENT_CODE=

# --- Feature flags ---
SFDA_BADGE_ENABLED=false
